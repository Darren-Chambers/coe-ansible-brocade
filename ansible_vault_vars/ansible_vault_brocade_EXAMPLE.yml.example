# Copy this file to ansible_vault_brocade_<brocade_switch>.yml for each
# real switch, fill in real values, then encrypt it:
#
#   ansible-vault encrypt ansible_vault_brocade_<brocade_switch>.yml
#
# <brocade_switch> must match the value passed as the brocade_switch
# extra_var when launching the job — this is how the playbook finds the
# right credentials for a given switch without HiSMOG or AAP extra_vars
# ever carrying the password directly.

fos_ip_addr: 10.10.10.10
fos_user_name: admin
fos_password: changeme
fos_https: true
